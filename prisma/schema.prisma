generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  role              Role      @default(USER)
  plan              Plan      @default(FREE)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  onboardingDone    Boolean   @default(false)
  orgName           String?
  industry          String?
  teamSize          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  honeypots    Honeypot[]
  threats      Threat[]
  canaryTokens CanaryToken[]
  reports      Report[]
  teamMembers  TeamMember[]  @relation("TeamOwner")
  memberOf     TeamMember[]  @relation("TeamUser")

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  lastActive   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TeamMember {
  id         String    @id @default(cuid())
  ownerId    String
  userId     String
  role       TeamRole  @default(VIEWER)
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?
  owner      User      @relation("TeamOwner", fields: [ownerId], references: [id])
  user       User      @relation("TeamUser", fields: [userId], references: [id])
}

model Honeypot {
  id            String         @id @default(cuid())
  userId        String
  name          String
  type          HoneypotType
  port          Int?
  status        HoneypotStatus @default(ACTIVE)
  description   String?
  generatedData Json?
  config        Json           @default("{}")
  totalHits     Int            @default(0)
  deployedAt    DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        Event[]
  canaryTokens  CanaryToken[]

  @@index([userId])
}

model Threat {
  id             String       @id @default(cuid())
  userId         String
  ipAddress      String
  ipPartial      String?
  firstSeen      DateTime     @default(now())
  lastSeen       DateTime?
  totalEvents    Int          @default(0)
  threatScore    Int          @default(0)
  attackerType   String?
  status         ThreatStatus @default(ACTIVE)
  osGuess        String?
  toolchain      Json         @default("[]")
  country        String?
  city           String?
  asn            String?
  radarScores    Json?
  llmAnalysis    String?
  rawFingerprint Json         @default("{}")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  events         Event[]

  @@index([userId])
}

model Event {
  id          String    @id @default(cuid())
  userId      String
  honeypotId  String?
  threatId    String?
  eventType   EventType
  timestamp   DateTime  @default(now())
  payload     Json      @default("{}")
  severity    Severity  @default(LOW)
  honeypot    Honeypot? @relation(fields: [honeypotId], references: [id])
  threat      Threat?   @relation(fields: [threatId], references: [id])

  @@index([userId])
  @@index([honeypotId])
}

model CanaryToken {
  id            String     @id @default(cuid())
  userId        String
  honeypotId    String?
  tokenHash     String     @unique
  tokenType     TokenType
  label         String?
  triggered     Boolean    @default(false)
  triggeredAt   DateTime?
  triggeredIp   String?
  triggeredMeta Json       @default("{}")
  createdAt     DateTime   @default(now())
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  honeypot      Honeypot?  @relation(fields: [honeypotId], references: [id])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  threatIds String[]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum TeamRole {
  OWNER
  ADMIN
  VIEWER
}

enum HoneypotType {
  SSH
  API
  SMTP
  S3
  DATABASE
}

enum HoneypotStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ThreatStatus {
  ACTIVE
  LURED
  TRAPPED
  BLOCKED
  RESOLVED
}

enum EventType {
  CONNECTION
  AUTH_ATTEMPT
  COMMAND
  FILE_ACCESS
  CANARY_TRIGGER
  EXFILTRATION
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TokenType {
  URL
  DNS
  DOCUMENT
  IMAGE
}
